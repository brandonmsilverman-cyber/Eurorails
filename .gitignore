# ── Secrets and credentials ──
# These files commonly contain passwords, API keys, or tokens.
# NEVER commit these to Git.
.env
.env.local
.env.production
.env.*.local
secrets/
*.key
*.pem
*.p12
credentials.json
service-account.json

# ── Personal and sensitive files ──
# Anything you wouldn't want a stranger to see.
passwords.txt
tax/
medical/
financial/
*.personal

# ── Operating system files ──
# macOS and Windows create hidden files you don't need in your project.
.DS_Store
Thumbs.db
Desktop.ini

# ── Dependencies ──
# Downloaded code libraries. These are large and can be re-downloaded
# by anyone using your project, so no need to store them.
node_modules/
__pycache__/
*.pyc
venv/
.venv/

# ── Build output ──
# Files generated by build tools. These can be regenerated.
dist/
build/
out/
*.min.js
*.min.css

# ── Logs ──
# Log files can get large and contain sensitive request data.
*.log
logs/
npm-debug.log*

# ── Editor and IDE files ──
# Your personal editor settings don't belong in shared projects.
.claude/
.vscode/
.idea/
*.swp
*.swo
*~

# ── Database files ──
# Local database files may contain user data.
*.sqlite
*.sqlite3
*.db

# ── Large binary files ──
# Reference files kept locally but not needed in the repo.
Eurorails\ map.webp
Eurorails\ Rules,\ Mayfair\ Games\ Inc.,\ 1990.pdf

# ── Backup files ──
*.bak
*.backup
